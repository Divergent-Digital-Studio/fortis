{
    "name": "fortis",
    "version": "1.0.3",
    "description": "Fortis - Network Security Monitor",
    "main": "./out/main/index.js",
    "scripts": {
        "dev": "electron-vite dev",
        "build": "electron-vite build",
        "preview": "electron-vite preview",
        "build:datasets": "node scripts/build-oui-map.mjs && node scripts/build-geoip.mjs && node scripts/build-world-land.mjs",
        "typecheck:node": "tsc --noEmit -p tsconfig.node.json",
        "typecheck:web": "tsc --noEmit -p tsconfig.web.json",
        "typecheck": "node scripts/typecheck.mjs",
        "test": "vitest run",
        "test:watch": "vitest",
        "test:coverage": "vitest run --coverage",
        "check": "npm run typecheck && npm run test && npm run build",
        "dist": "npm run build && electron-builder",
        "dist:dir": "npm run build && electron-builder --dir",
        "dist:mac": "npm run build && electron-builder --mac",
        "dist:win": "npm run build && electron-builder --win",
        "dist:linux": "npm run build && electron-builder --linux AppImage deb",
        "release": "npm run build && electron-builder --publish onTagOrDraft",
        "build:site": "node scripts/build-site.mjs",
        "agent": "npm run build && env ELECTRON_RUN_AS_NODE=1 ./node_modules/.bin/electron out/main/agent.js"
    },
    "keywords": [
        "electron",
        "security",
        "network",
        "monitor"
    ],
    "author": "Fortis contributors",
    "license": "MIT",
    "dependencies": {
        "@ai-sdk/anthropic": "^3.0.51",
        "@ai-sdk/openai": "^3.0.38",
        "ai": "^6.0.106",
        "better-sqlite3-multiple-ciphers": "^12.11.1",
        "electron-updater": "^6.8.9",
        "lucide-react": "^0.575.0",
        "react": "^19.2.4",
        "react-dom": "^19.2.4",
        "recharts": "^3.7.0",
        "systeminformation": "^5.31.1",
        "ws": "^8.21.0",
        "zustand": "^5.0.11"
    },
    "devDependencies": {
        "@testing-library/jest-dom": "^6.9.1",
        "@testing-library/react": "^16.3.2",
        "@testing-library/user-event": "^14.6.1",
        "@types/react": "^19.2.14",
        "@types/react-dom": "^19.2.3",
        "@types/ws": "^8.18.1",
        "@vitejs/plugin-react": "^5.1.4",
        "@vitest/coverage-v8": "^4.1.9",
        "electron": "^40.6.1",
        "electron-builder": "^26.8.1",
        "electron-vite": "^5.0.0",
        "esbuild": "^0.25.12",
        "js-yaml": "^4.2.0",
        "jsdom": "^25.0.1",
        "png-to-ico": "^3.0.1",
        "sharp": "^0.35.2",
        "typescript": "^5.9.3",
        "vite": "^6.4.1",
        "vitest": "^4.1.9"
    }
}
